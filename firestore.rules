// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (uid)
// Fields:
//   - name: string (required)
//   - email: string (required)
//   - role: string (admin, supervisor, seller, plant_manager)
//   - status: string (active, inactive)
//
// Collection: inventory
// Document ID: global
// Fields:
//   - plantStock: number
//   - inRoute: number
//   - sold: number
//   - returned: number
//
// Collection: sales
// Document ID: auto-generated
// Fields:
//   - sellerId: string (required)
//   - correlative: string (required)
//   - bottleCount: number (required)
//   - totalAmount: number (required)
//   - timestamp: timestamp (required)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "bwpsoporte@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSeller() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /inventory/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /dispatches/{dispatchId} {
      allow read: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /closures/{closureId} {
      allow read: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /test/{docId} {
      allow read: if true;
    }
  }
}
